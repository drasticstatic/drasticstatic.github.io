# ============================================================
# .gitignore — drasticstatic.github.io (portfolio landing page)
# ============================================================

# macOS system files
.DS_Store
.AppleDouble
.LSOverride
._*
.Spotlight-V100
.Trashes
Icon?
.fseventsd

# Windows & Linux system files
Thumbs.db
desktop.ini
$RECYCLE.BIN/

# Credentials & secrets (absolute — no exceptions)
.env
.env.*
!.env.example
*.key
*.pem
credentials/
secrets/

# Editor / IDE
.vscode/
.idea/
*.swp
*.swo
*~

# Logs & temp
*.log
*.tmp
*.temp
tmp/
temp/

# Claude Code local config
.claude/*
!.claude/skills/
